@page "/lobby/room/{RoomId}"
@page "/multiplayer/room/{RoomId}"
@layout RoomLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using WordGame.Multiplayer.Contracts
@using WordGameUk.Components.Layout
@inject NavigationManager Navigation

<PageTitle>Room</PageTitle>

<div class="flex flex-column justify-content-center">
    <p>
        <a href="/lobby">Back to lobby</a>
    </p>

    @if (room is null)
    {
        <p>Joining room...</p>
    }
    else
    {
        <div class="grid grid-cols-3 gap-2">
            @foreach (var _ in Enumerable.Range(0, 8))
            {
                <div class="border-2">xxx</div>
            }
        </div>
        
        <div class="basis-1/3">
            <input placeholder="Your word"/>
        </div>
        @*<div class="card">
            <h1>Room</h1>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">@room.Name</h2>
                    <button class="btn btn-sm btn-outline-danger" @onclick="LeaveRoomAsync">Leave</button>
                </div>

                <p class="mb-2">Status: @room.StatusMessage</p>

                @if (room.IsInProgress)
                {
                    <p class="mb-2"><strong>Fragment:</strong> @room.CurrentFragment</p>
                    <p class="mb-2"><strong>Turn:</strong> @CurrentTurnName()</p>
                    <p class="mb-2"><strong>Time Left:</strong> @room.SecondsLeft s</p>
                }
                else if (room.IsFinished)
                {
                    <p class="mb-2"><strong>Winner:</strong> @room.WinnerName</p>
                }

                <div class="mb-3">
                    <button class="btn btn-success" disabled="@(!CanStart())" @onclick="StartGameAsync">Start Game
                    </button>
                </div>

                <form @onsubmit="SubmitGuessAsync" @onsubmit:preventDefault>
