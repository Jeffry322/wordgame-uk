@page "/lobby/room/{RoomId}"
@page "/multiplayer/room/{RoomId}"
@layout RoomLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using WordGame.Multiplayer.Contracts
@using WordGameUk.Components.Layout
@inject NavigationManager Navigation

<PageTitle>Room</PageTitle>

<div class="flex flex-col h-full pt-4">
    @if (room is null)
    {
        <p>Joining room...</p>
    }
    else
    {
        <div class="flex justify-end px-4 pb-2">
            <button class="px-4 py-2 bg-blue-600 rounded-2xl" @onclick="AddMockPlayer">
                Add Player
            </button>
        </div>

        <div class="grid grid-cols-3 gap-2 flex-1">
            <div class="flex flex-col gap-2 h-full">
                @foreach (var player in GetLeft())
                {
                    <div @key="player.Id" class="flex flex-1 items-center justify-center border p-4 m-2 player-enter">
                        @player.Name
                    </div>
                }
            </div>
            <div class="flex items-center justify-center">
                <div class="w-56 h-56 flex items-center justify-center font-mono text-4xl">
                    FRAGMENT
                </div>
            </div>
            <div class="flex flex-col gap-2 h-full">
                @foreach (var player in GetRight())
                {
                    <div @key="player.Id" class="flex flex-1 items-center justify-center border p-4 m-2 player-enter">
                        @player.Name
                    </div>
                }
            </div>
        </div>

        <div class="flex flex-row p-4 gap-2">
            <input class="border rounded-3xl flex-1 px-3 py-2" placeholder="Your word"/>
            <button class="px-4 bg-green-600" style="border-radius: 24px">Submit</button>
        </div>
        @*<div class="card">
            <h1>Room</h1>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">@room.Name</h2>
                    <button class="btn btn-sm btn-outline-danger" @onclick="LeaveRoomAsync">Leave</button>
                </div>

                <p class="mb-2">Status: @room.StatusMessage</p>

                

        @if (room.IsInProgress)
                {
                    <p class="mb-2"><strong>Fragment:</strong> @room.CurrentFragment</p>
                    <p class="mb-2"><strong>Turn:</strong> @CurrentTurnName()</p>
                    <p class="mb-2"><strong>Time Left:</strong> @room.SecondsLeft s</p>
                }
                else if (room.IsFinished)
                {
                    <p class="mb-2"><strong>Winner:</strong> @room.WinnerName</p>
                }

                <div class="mb-3">
                    <button class="btn btn-success" disabled="@(!CanStart())" @onclick="StartGameAsync">Start Game
                    </button>
                </div>

                <form @onsubmit="SubmitGuessAsync" @onsubmit:preventDefault>
                    <div class="d-flex gap-2">
                        <input class="form-control" @bind="guessWord" placeholder="Your word"/>
                        <button class="btn btn-primary" type="submit" disabled="@(!CanGuess())">Submit</button>
                    </div>
                </form>

                <hr/>
                <h3 class="h6">Players</h3>
                <ul class="mb-0">
                    
        @foreach (var player in room.Players)
                    {
                        <li>@PlayerRow(player)</li>
                    }
                </ul>
            </div>
        </div>*@
    }

    @if (!string.IsNullOrWhiteSpace(uiMessage))
    {
        <p class="mt-3" role="status">@uiMessage</p>
    }
</div>

<style>
    .player-enter {
        animation: playerEnter 350ms ease-out;
    }

    @@keyframes playerEnter {
        from {
            opacity: 0;
            transform: translateY(10px) scale(0.96);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
</style>

@code {

    [Parameter]
    public string RoomId { get; set; } = string.Empty;

    private HubConnection? connection;
    private string currentConnectionId = string.Empty;
    private string guessWord = string.Empty;
    private string uiMessage = string.Empty;
    private RoomSnapshotDto? room;
    private int nextMockPlayerId = 1;
    private readonly List<MockPlayer> mockPlayers = [];

    protected override async Task OnInitializedAsync()
    {
        connection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/multiplayer"))
            .WithAutomaticReconnect()
            .Build();

        connection.On<string>("Connected",
            id =>
            {
                currentConnectionId = id;
                return InvokeAsync(StateHasChanged);
            });

        connection.On<RoomSnapshotDto>("RoomUpdated",
            snapshot =>
            {
                if (snapshot.RoomId != RoomId)
                {
                    return Task.CompletedTask;
                }

                room = snapshot;
                if (mockPlayers.Count == 0)
                {
                    foreach (var player in snapshot.Players)
                    {
                        mockPlayers.Add(new MockPlayer(nextMockPlayerId++, player.Name));
                    }
                }

                return InvokeAsync(StateHasChanged);
            });

        connection.On<string>("RoomClosed",
            roomId =>
            {
                if (roomId == RoomId)
                {
                    uiMessage = "Room was closed.";
                    room = null;
                    Navigation.NavigateTo("/lobby");
                }

                return InvokeAsync(StateHasChanged);
            });

        await connection.StartAsync();
        var joined = await connection.InvokeAsync<bool>("JoinRoom", RoomId);
        if (!joined)
        {
            uiMessage = "Room not found or unavailable.";
            Navigation.NavigateTo("/lobby");
        }
    }

    private async Task StartGameAsync()
    {
        if (connection is null)
            return;

        await connection.SendAsync("StartGame", RoomId);
    }

    private async Task SubmitGuessAsync()
    {
        if (connection is null || string.IsNullOrWhiteSpace(guessWord))
            return;

        await connection.SendAsync("SubmitWord", RoomId, guessWord);
        guessWord = string.Empty;
    }

    private async Task LeaveRoomAsync()
    {
        if (connection is not null)
            await connection.SendAsync("LeaveRoom", RoomId);

        Navigation.NavigateTo("/lobby");
    }

    private bool CanStart()
    {
        if (room is null)
            return false;

        return !room.IsInProgress && !room.IsFinished && room.Players.Count >= 2;
    }

    private bool CanGuess()
    {
        if (room is null || !room.IsInProgress)
            return false;

        return room.CurrentTurnConnectionId == currentConnectionId;
    }

    private string CurrentTurnName()
    {
        if (room is null)
            return "-";

        var current = room.Players.FirstOrDefault(x => x.IsCurrentTurn);
        return current?.Name ?? "-";
    }

    private string PlayerRow(RoomPlayerDto player)
    {
        var me = player.ConnectionId == currentConnectionId ? " (you)" : string.Empty;
        var turn = player.IsCurrentTurn ? " <- turn" : string.Empty;
        var eliminated = player.IsEliminated ? " [out]" : string.Empty;
        return $"{player.Name}{me} | lives: {player.Lives}{eliminated}{turn}";
    }

    private void AddMockPlayer()
    {
        mockPlayers.Add(new MockPlayer(nextMockPlayerId, $"Player {nextMockPlayerId}"));
        nextMockPlayerId++;
    }

    private IEnumerable<MockPlayer> GetLeft()
    {
        var list = mockPlayers.ToList();
        var leftCount = (int)Math.Ceiling(list.Count / 2.0);

        return list.Take(leftCount);
    }

    private IEnumerable<MockPlayer> GetRight()
    {
        var list = mockPlayers.ToList();
        var leftCount = (int)Math.Ceiling(list.Count / 2.0);

        return list.Skip(leftCount);
    }

    private sealed record MockPlayer(
        int Id,
        string Name);

    public async ValueTask DisposeAsync()
    {
        if (connection is null)
            return;

        await connection.DisposeAsync();
    }

}
