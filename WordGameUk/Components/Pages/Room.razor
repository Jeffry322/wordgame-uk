@page "/lobby/room/{RoomId}"
@page "/multiplayer/room/{RoomId}"
@layout RoomLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using WordGameUk.Multiplayer.Core.Multiplayer.Contracts
@inject NavigationManager Navigation
@inject PlayerSessionStorage PlayerSessionStorage
@inject RoomTopBarState TopBarState
@inject IJSRuntime Js

<PageTitle>Room</PageTitle>

<div class="flex flex-col h-full pt-4">
    @if (room is null)
    {
        <p>Joining room...</p>
    }
    else
    {
        <div class="grid grid-cols-3 gap-2 flex-1">
            <div class="flex flex-col items-center justify-center gap-3 py-2">
                @foreach (var player in GetLeftPlayers(room.Players))
                {
                    <div @key="player.PlayerId" class="@PlayerCardClass(player)">
                        @if (TryGetPlayerEffect(player.PlayerId, out var effect) && ShouldShowEffectBadge(effect))
                        {
                            <div class="@PlayerEffectBadgeClass(effect)">@PlayerEffectIcon(effect)</div>
                        }
                        <div class="flex flex-col items-center gap-2 text-center">
                            <div
                                class="flex h-16 w-16 items-center justify-center rounded-full bg-white/15 text-xl font-semibold uppercase text-white/90 shadow-inner">
                                @PlayerInitials(player.Name)
                            </div>
                            <p class="text-lg leading-none">
                                @player.Name
                                @if (player.PlayerId == currentPlayerId)
                                {
                                    <span class="text-xs opacity-75">(you)</span>
                                }
                            </p>
                            @if (IsDisconnectedInGame(player))
                            {
                                <p class="text-xs font-medium uppercase tracking-wide text-amber-200">Reconnecting...</p>
                            }
                            <p class="text-sm leading-none">@LivesHearts(player)</p>
                            @if (ShouldShowPlayerTyping(player))
                            {
                                <p class="max-w-32 truncate font-mono text-base leading-none text-emerald-100">
                                    @TypingTextForPlayer(player)
                                </p>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="flex items-center justify-center">
                @if (!room.IsInProgress)
                {
                    <div class="flex w-72 flex-col items-center gap-3 text-center">
                        <p class="text-sm opacity-80">Queued players: @QueuedPlayersCount() / @room.Players.Count</p>
                        <button
                            class="w-full rounded-2xl border border-sky-500 px-6 py-3 text-lg disabled:cursor-not-allowed disabled:opacity-40"
                            disabled="@string.IsNullOrWhiteSpace(currentPlayerId)"
                            @onclick="ToggleQueueStateAsync">
                            @(IsCurrentPlayerQueued() ? "Leave game queue" : "Join game")
                        </button>
                        <button
                            class="w-full rounded-2xl bg-emerald-600 px-6 py-3 text-lg disabled:cursor-not-allowed disabled:opacity-40"
                            disabled="@(!CanStart())"
                            @onclick="StartGameAsync">
                            Start Game
                        </button>

                        <div class="mt-2 w-full rounded-xl border border-white/15 bg-black/15 p-3 text-left">
                            <p class="mb-1 text-xs uppercase tracking-wide opacity-75">Waiting List</p>
                            @{
                                var waitingPlayers = GetWaitingPlayers(room.Players);
                            }
                            @if (waitingPlayers.Count == 0)
                            {
                                <p class="text-sm opacity-70">Nobody is waiting.</p>
                            }
                            else
                            {
                                @foreach (var waitingPlayer in waitingPlayers)
                                {
                                    <p class="text-sm leading-6">
                                        @waitingPlayer.Name
                                        @if (waitingPlayer.PlayerId == currentPlayerId)
                                        {
                                            <span class="text-xs opacity-75">(you)</span>
                                        }
                                    </p>
                                }
                            }
                        </div>
                    </div>
                }
                else if (room.IsInProgress)
                {
                    <div class="flex flex-col items-center gap-2">
                        <div class="w-56 h-56 flex items-center justify-center font-mono text-4xl">
                            @room.CurrentFragment
                        </div>
                        <p class="text-xl">Turn: @CurrentTurnName()</p>
                        <p class="text-lg">Time Left: @room.SecondsLeft s</p>
                    </div>
                }
            </div>
            <div class="flex flex-col items-center justify-center gap-3 py-2">
                @foreach (var player in GetRightPlayers(room.Players))
                {
                    <div @key="player.PlayerId" class="@PlayerCardClass(player)">
                        @if (TryGetPlayerEffect(player.PlayerId, out var effect) && ShouldShowEffectBadge(effect))
                        {
                            <div class="@PlayerEffectBadgeClass(effect)">@PlayerEffectIcon(effect)</div>
                        }
                        <div class="flex flex-col items-center gap-2 text-center">
                            <div
                                class="flex h-16 w-16 items-center justify-center rounded-full bg-white/15 text-xl font-semibold uppercase text-white/90 shadow-inner">
                                @PlayerInitials(player.Name)
                            </div>
                            <p class="text-lg leading-none">
                                @player.Name
                                @if (player.PlayerId == currentPlayerId)
                                {
                                    <span class="text-xs opacity-75">(you)</span>
                                }
                            </p>
                            @if (IsDisconnectedInGame(player))
                            {
                                <p class="text-xs font-medium uppercase tracking-wide text-amber-200">Reconnecting...</p>
                            }
                            <p class="text-sm leading-none">@LivesHearts(player)</p>
                            @if (ShouldShowPlayerTyping(player))
                            {
                                <p class="max-w-32 truncate font-mono text-base leading-none text-emerald-100">
                                    @TypingTextForPlayer(player)
                                </p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <form class="flex min-h-21 items-center gap-2 bg-black/20 px-4 py-3 backdrop-blur-sm"
              @onsubmit="SubmitGuessAsync" @onsubmit:preventDefault>
            @if (CanGuess())
            {
                <input class="flex-1 rounded-3xl border px-4 py-3 text-lg"
                       placeholder="Your word"
                       @ref="guessInputRef"
                       value="@guessWord"
                       @oninput="OnGuessInputChanged"
                       disabled="@(!CanGuess())"/>
                <button
                    class="rounded-3xl bg-green-600 px-5 py-3 text-lg disabled:cursor-not-allowed disabled:opacity-40"
                    type="submit"
                    disabled="@(!CanGuess())">
                    Submit
                </button>
            }
            else
            {
                <div class="flex-1 text-center text-lg opacity-70">
                    @(room?.IsInProgress == true ? "Waiting for your turn..." : "Join game queue to play.")
                </div>
            }
        </form>
    }
</div>

<style>
    .player-shake {
        animation: playerShake 360ms ease-in-out;
    }

    .player-effect-pop {
        pointer-events: none;
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        font-size: 3rem;
        line-height: 1;
        text-shadow: 0 8px 22px rgba(0, 0, 0, 0.45);
        animation: playerEffectPop 700ms ease-out forwards;
    }

    @@keyframes playerShake {
        0%, 100% {
            transform: translateX(0);
        }
        20% {
            transform: translateX(-6px);
        }
        40% {
            transform: translateX(6px);
        }
        60% {
            transform: translateX(-4px);
        }
        80% {
            transform: translateX(4px);
        }
    }

    @@keyframes playerEffectPop {
        0% {
            opacity: 0;
            transform: translate(-50%, -50%) scale(0.35);
        }
        20% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
        100% {
            opacity: 0;
            transform: translate(-50%, -120%) scale(1.08);
        }
    }
</style>

@code {

    [Parameter]
    public string RoomId { get; set; } = string.Empty;

    private HubConnection? connection;
    private string currentPlayerId = string.Empty;
    private string guessWord = string.Empty;
    private string uiMessage = string.Empty;
    private RoomSnapshotDto? room;
    private ElementReference guessInputRef;
    private bool wasMyTurn;
    private bool shouldFocusInput;
    private bool displayNameLoaded;
    private bool joinInProgress;
    private string typingPlayerId = string.Empty;
    private string typingText = string.Empty;
    private string lastTypingSent = string.Empty;
    private readonly Dictionary<string, PlayerEffect> playerEffects = new();
    private readonly Dictionary<string, int> playerEffectVersions = new();
    private readonly Dictionary<string, DateTimeOffset> disconnectedSinceUtc = new();

    protected override async Task OnInitializedAsync()
    {
        TopBarState.Update("Joining room...",
            string.Empty,
            string.Empty,
            false,
            null);

        connection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/multiplayer"))
            .WithAutomaticReconnect()
            .Build();

        connection.Reconnecting += _ =>
        {
            uiMessage = "Connection lost. Reconnecting...";
            UpdateTopBarState();
            return InvokeAsync(StateHasChanged);
        };

        connection.Reconnected += _ =>
        {
            return InvokeAsync(async () =>
            {
                await EnsurePlayerIdAsync();
                await ApplyStoredDisplayNameAsync();
                await JoinRoomAsync();
            });
        };

        connection.On<RoomSnapshotDto>("RoomUpdated",
            snapshot =>
            {
                if (snapshot.RoomId != RoomId)
                {
                    return Task.CompletedTask;
                }

                room = snapshot;
                TrackDisconnectedPlayers(snapshot);
                var isMyTurn = snapshot.IsInProgress && snapshot.CurrentTurnPlayerId == currentPlayerId;
                if (isMyTurn && !wasMyTurn)
                {
                    shouldFocusInput = true;
                }

                if (!snapshot.IsInProgress
                    || string.IsNullOrWhiteSpace(snapshot.CurrentTurnPlayerId)
                    || snapshot.CurrentTurnPlayerId != typingPlayerId
                    || IsCurrentTurnDisconnected(snapshot))
                {
                    ClearTypingIndicator();
                }

                if (!isMyTurn)
                    lastTypingSent = string.Empty;

                wasMyTurn = isMyTurn;
                UpdateTopBarState();
                return InvokeAsync(StateHasChanged);
            });

        connection.On<TypingUpdateDto>("TypingUpdated",
            update =>
            {
                if (room is null || !room.IsInProgress || room.CurrentTurnPlayerId != update.PlayerId)
                {
                    ClearTypingIndicator();
                    return InvokeAsync(StateHasChanged);
                }

                if (string.IsNullOrWhiteSpace(update.Text))
                {
                    ClearTypingIndicator();
                    return InvokeAsync(StateHasChanged);
                }

                typingPlayerId = update.PlayerId;
                typingText = update.Text;
                return InvokeAsync(StateHasChanged);
            });

        connection.On<GuessFeedbackDto>("GuessFeedback",
            feedback =>
            {
                if (feedback.Outcome == WordGuessOutcome.Correct)
                {
                    TriggerPlayerEffect(feedback.PlayerId, PlayerEffect.Success);
                }
                else if (feedback.Outcome == WordGuessOutcome.Incorrect)
                {
                    TriggerPlayerEffect(feedback.PlayerId, PlayerEffect.Shake);
                }

                return InvokeAsync(StateHasChanged);
            });

        connection.On<PlayerLifeLostDto>("PlayerLifeLost",
            lifeLost =>
            {
                TriggerPlayerEffect(lifeLost.PlayerId, PlayerEffect.Damage);
                return InvokeAsync(StateHasChanged);
            });

        connection.On<string>("RoomClosed",
            async roomId =>
            {
                if (roomId == RoomId)
                {
                    uiMessage = "Room was closed.";
                    room = null;
                    UpdateTopBarState();
                    await ClearRoomPresenceAsync();
                    Navigation.NavigateTo("/lobby");
                }

                await InvokeAsync(StateHasChanged);
            });

        await connection.StartAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !displayNameLoaded)
        {
            displayNameLoaded = true;
            await EnsurePlayerIdAsync();
            await SetRoomPresenceAsync();
            await ApplyStoredDisplayNameAsync();
            await JoinRoomAsync();
        }

        if (!shouldFocusInput || !CanGuess())
            return;

        shouldFocusInput = false;
        await guessInputRef.FocusAsync();
    }

    private async Task StartGameAsync()
    {
        if (connection is null)
            return;

        await connection.SendAsync("StartGame", RoomId);
    }

    private async Task ToggleQueueStateAsync()
    {
        if (connection is null || string.IsNullOrWhiteSpace(currentPlayerId) || room is null || room.IsInProgress)
            return;

        await connection.SendAsync("SetPlayerInGame", RoomId, currentPlayerId, !IsCurrentPlayerQueued());
    }

    private async Task SubmitGuessAsync()
    {
        if (connection is null || string.IsNullOrWhiteSpace(guessWord) || string.IsNullOrWhiteSpace(currentPlayerId))
            return;

        await SendTypingUpdateAsync(string.Empty);
        var outcome = await connection.InvokeAsync<WordGuessOutcome>("SubmitWord", RoomId, currentPlayerId, guessWord);
        if (outcome == WordGuessOutcome.Rejected)
        {
            uiMessage = "Guess was rejected.";
        }

        guessWord = string.Empty;
        lastTypingSent = string.Empty;
        ClearTypingIndicator();
    }

    private async Task OnGuessInputChanged(ChangeEventArgs args)
    {
        guessWord = args.Value?.ToString() ?? string.Empty;

        if (!CanGuess())
            return;

        await SendTypingUpdateAsync(guessWord);
    }

    private async Task SendTypingUpdateAsync(string text)
    {
        if (connection is null || string.IsNullOrWhiteSpace(currentPlayerId) || room is null || !room.IsInProgress)
            return;

        var normalized = text.Trim();
        if (normalized.Length > 32)
            normalized = normalized[..32];

        if (string.IsNullOrWhiteSpace(normalized))
            ClearTypingIndicator();
        else
        {
            typingPlayerId = currentPlayerId;
            typingText = normalized;
        }

        if (lastTypingSent == normalized)
            return;

        lastTypingSent = normalized;
        await connection.SendAsync("UpdateTyping", RoomId, currentPlayerId, normalized);
    }

    private async Task LeaveRoomAsync()
    {
        if (connection is not null)
            await connection.SendAsync("LeaveRoom", RoomId);

        await ClearRoomPresenceAsync();
        TopBarState.Clear();
        Navigation.NavigateTo("/lobby");
    }

    private async Task JoinRoomAsync()
    {
        if (connection is null || string.IsNullOrWhiteSpace(currentPlayerId) || joinInProgress)
            return;

        joinInProgress = true;
        try
        {
            const int maxAttempts = 16;
            for (var attempt = 1; attempt <= maxAttempts; attempt++)
            {
                if (connection.State != HubConnectionState.Connected)
                    return;

                JoinRoomResult joinResult;
                try
                {
                    joinResult = await connection.InvokeAsync<JoinRoomResult>("JoinRoom", RoomId, currentPlayerId);
                }
                catch (InvalidOperationException) when (connection.State != HubConnectionState.Connected)
                {
                    return;
                }

                if (joinResult is JoinRoomResult.Joined or JoinRoomResult.Reconnected)
                {
                    uiMessage = string.Empty;
                    UpdateTopBarState();
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                if (joinResult == JoinRoomResult.AlreadyInRoom && attempt < maxAttempts)
                {
                    await Task.Delay(1000);
                    continue;
                }

                uiMessage = joinResult switch
                {
                    JoinRoomResult.AlreadyInRoom => "You are already connected to this room from another tab/window.",
                    JoinRoomResult.NotFound => "Room was not found.",
                    JoinRoomResult.Unavailable => "Unable to join room.",
                    _ => "Unable to join room."
                };

                UpdateTopBarState();
                await InvokeAsync(StateHasChanged);
                await ClearRoomPresenceAsync();
                Navigation.NavigateTo("/lobby");
                return;
            }
        }
        finally
        {
            joinInProgress = false;
        }

        if (connection.State != HubConnectionState.Connected)
            return;

        uiMessage = "Unable to rejoin room. Please try opening the room again.";
        UpdateTopBarState();
        await InvokeAsync(StateHasChanged);
        await ClearRoomPresenceAsync();
        Navigation.NavigateTo("/lobby");
    }

    private async Task ApplyStoredDisplayNameAsync()
    {
        if (connection is null || string.IsNullOrWhiteSpace(currentPlayerId))
            return;

        var storedName = await PlayerSessionStorage.GetDisplayNameAsync();
        if (string.IsNullOrWhiteSpace(storedName))
            return;

        var normalizedName = PlayerSessionStorage.NormalizeDisplayName(storedName);
        await connection.SendAsync("SetDisplayName", currentPlayerId, normalizedName);
    }

    private async Task EnsurePlayerIdAsync()
    {
        currentPlayerId = await PlayerSessionStorage.GetOrCreatePlayerIdAsync();
    }

    private async Task SetRoomPresenceAsync()
    {
        if (string.IsNullOrWhiteSpace(currentPlayerId))
            return;

        await Js.InvokeVoidAsync("wordGameRoomPresence.set", RoomId, currentPlayerId);
    }

    private async Task ClearRoomPresenceAsync()
    {
        try
        {
            await Js.InvokeVoidAsync("wordGameRoomPresence.clear");
        }
        catch (JSDisconnectedException)
        {
            // Browser already disconnected; nothing to clear.
        }
    }

    private bool CanStart()
    {
        if (room is null)
            return false;

        return !room.IsInProgress && QueuedPlayersCount() >= 2;
    }

    private int QueuedPlayersCount()
    {
        if (room is null)
            return 0;

        return room.Players.Count(x => x.IsInGame);
    }

    private bool IsCurrentPlayerQueued()
    {
        if (room is null || string.IsNullOrWhiteSpace(currentPlayerId))
            return false;

        return room.Players.Any(x => x.PlayerId == currentPlayerId && x.IsInGame);
    }

    private bool CanGuess()
    {
        if (room is null || !room.IsInProgress)
            return false;

        return room.CurrentTurnPlayerId == currentPlayerId;
    }

    private string CurrentTurnName()
    {
        if (room is null)
            return "-";

        var current = room.Players.FirstOrDefault(x => x.IsCurrentTurn);
        return current?.Name ?? "-";
    }

    private string PlayerCardClass(RoomPlayerDto player)
    {
        var baseClass = "relative h-52 w-36 flex items-center justify-center rounded-2xl px-3 py-4 transition";
        var eliminatedClass = player.IsEliminated ? " opacity-45 grayscale bg-black/25" : " bg-white/10";
        var disconnectedClass = IsDisconnectedInGame(player) ? " opacity-55 saturate-50 ring-1 ring-amber-200/60" : string.Empty;
        var effectClass = playerEffects.TryGetValue(player.PlayerId, out var effect) && effect == PlayerEffect.Shake
            ? " player-shake"
            : string.Empty;

        if (room is not null && room.IsInProgress && player.IsCurrentTurn && !player.IsEliminated && player.IsConnected)
            return $"{baseClass}{eliminatedClass}{disconnectedClass}{effectClass} ring-2 ring-emerald-300 shadow-[0_0_24px_rgba(110,231,183,0.55)]";

        return $"{baseClass}{eliminatedClass}{disconnectedClass}{effectClass}";
    }

    private bool IsDisconnectedInGame(RoomPlayerDto player)
    {
        if (room is null || !room.IsInProgress || player.IsConnected)
            return false;

        if (!disconnectedSinceUtc.TryGetValue(player.PlayerId, out var disconnectedSince))
            return false;

        return DateTimeOffset.UtcNow - disconnectedSince >= TimeSpan.FromMilliseconds(800);
    }

    private static bool IsCurrentTurnDisconnected(RoomSnapshotDto snapshot)
    {
        if (string.IsNullOrWhiteSpace(snapshot.CurrentTurnPlayerId))
            return false;

        var currentPlayer = snapshot.Players.FirstOrDefault(x => x.PlayerId == snapshot.CurrentTurnPlayerId);
        return currentPlayer is not null && !currentPlayer.IsConnected;
    }

    private void TrackDisconnectedPlayers(RoomSnapshotDto snapshot)
    {
        if (!snapshot.IsInProgress)
        {
            disconnectedSinceUtc.Clear();
            return;
        }

        var playerIdsInSnapshot = new HashSet<string>(snapshot.Players.Select(x => x.PlayerId));
        foreach (var trackedId in disconnectedSinceUtc.Keys.Where(x => !playerIdsInSnapshot.Contains(x)).ToList())
            disconnectedSinceUtc.Remove(trackedId);

        var now = DateTimeOffset.UtcNow;
        foreach (var player in snapshot.Players)
        {
            if (player.IsConnected)
            {
                disconnectedSinceUtc.Remove(player.PlayerId);
                continue;
            }

            disconnectedSinceUtc.TryAdd(player.PlayerId, now);
        }
    }

    private bool TryGetPlayerEffect(string playerId, out PlayerEffect effect)
    {
        if (playerEffects.TryGetValue(playerId, out effect))
            return true;

        effect = PlayerEffect.None;
        return false;
    }

    private static string PlayerEffectBadgeClass(PlayerEffect effect)
    {
        var baseClass = "player-effect-pop";
        return effect switch
        {
            PlayerEffect.Success => $"{baseClass}",
            PlayerEffect.Damage => $"{baseClass}",
            PlayerEffect.Shake => $"{baseClass}",
            _ => baseClass
        };
    }

    private static bool ShouldShowEffectBadge(PlayerEffect effect) => effect is PlayerEffect.Success or PlayerEffect.Damage;

    private static string PlayerEffectIcon(PlayerEffect effect)
    {
        return effect switch
        {
            PlayerEffect.Success => "✅",
            PlayerEffect.Damage => "❌",
            _ => string.Empty
        };
    }

    private string LivesHearts(RoomPlayerDto player)
    {
        var maxLives = room?.MaxLives ?? player.Lives;
        if (maxLives < player.Lives)
            maxLives = player.Lives;

        var remaining = string.Concat(Enumerable.Repeat("❤️", player.Lives));
        var lost = string.Concat(Enumerable.Repeat("🖤", maxLives - player.Lives));
        return $"{remaining}{lost}";
    }

    private static string PlayerInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0][..1];

        return $"{parts[0][..1]}{parts[^1][..1]}";
    }

    private static IReadOnlyList<RoomPlayerDto> GetLeftPlayers(IReadOnlyCollection<RoomPlayerDto> players)
    {
        var list = players.Where(x => x.IsInGame).ToList();
        var leftCount = (int)Math.Ceiling(list.Count / 2.0);

        return list.Take(leftCount).ToList();
    }

    private static IReadOnlyList<RoomPlayerDto> GetRightPlayers(IReadOnlyCollection<RoomPlayerDto> players)
    {
        var list = players.Where(x => x.IsInGame).ToList();
        var leftCount = (int)Math.Ceiling(list.Count / 2.0);

        return list.Skip(leftCount).ToList();
    }

    private static IReadOnlyList<RoomPlayerDto> GetWaitingPlayers(IReadOnlyCollection<RoomPlayerDto> players)
    {
        return players.Where(x => !x.IsInGame).ToList();
    }

    private bool ShouldShowPlayerTyping(RoomPlayerDto player)
    {
        return room is not null
               && room.IsInProgress
               && !string.IsNullOrWhiteSpace(typingText)
               && room.CurrentTurnPlayerId == typingPlayerId
               && player.PlayerId == typingPlayerId;
    }

    private string TypingTextForPlayer(RoomPlayerDto player)
    {
        if (!ShouldShowPlayerTyping(player))
            return string.Empty;

        return typingText;
    }

    private void ClearTypingIndicator()
    {
        typingPlayerId = string.Empty;
        typingText = string.Empty;
    }

    private void TriggerPlayerEffect(string playerId, PlayerEffect effect)
    {
        var version = 1;
        if (playerEffectVersions.TryGetValue(playerId, out var currentVersion))
        {
            version = currentVersion + 1;
        }

        playerEffectVersions[playerId] = version;
        playerEffects[playerId] = effect;
        _ = ClearPlayerEffectAsync(playerId, version);
    }

    private async Task ClearPlayerEffectAsync(string playerId, int version)
    {
        await Task.Delay(700);
        if (!playerEffectVersions.TryGetValue(playerId, out var currentVersion) || currentVersion != version)
            return;

        playerEffects.Remove(playerId);
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateTopBarState()
    {
        if (room is null)
        {
            var title = string.IsNullOrWhiteSpace(uiMessage) ? "Joining room..." : uiMessage;
            TopBarState.Update(title,
                string.Empty,
                string.Empty,
                false,
                null);
            return;
        }

        var status = room.IsInProgress ? "In Progress" : "Waiting";
        var subtitle = $"{room.Players.Count} player(s) • {status}";

        string meta;
        if (room.IsInProgress)
        {
            meta = $"Turn: {CurrentTurnName()} • {room.SecondsLeft}s";
        }
        else if (!CanStart())
        {
            meta = "Need at least 2 queued players to start.";
        }
        else
        {
            meta = string.Empty;
        }

        TopBarState.Update(room.Name,
            subtitle,
            meta,
            true,
            LeaveRoomAsync);
    }

    public async ValueTask DisposeAsync()
    {
        TopBarState.Clear();
        await ClearRoomPresenceAsync();

        if (connection is null)
            return;

        await connection.DisposeAsync();
    }

    private enum PlayerEffect
    {
        None,
        Success,
        Damage,
        Shake
    }

}
