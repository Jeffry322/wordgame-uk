@page "/lobby"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using WordGame.Multiplayer.Contracts
@inject NavigationManager Navigation

<PageTitle>Multiplayer Lobby</PageTitle>

<h1 class="mb-6 text-3xl font-bold tracking-tight text-slate-900">Multiplayer Lobby</h1>

<div class="mb-4 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
    <label for="name-input" class="mb-2 block text-sm font-medium text-slate-700">Display Name</label>
    <div class="flex gap-2">
        <input id="name-input"
               class="w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
               @bind="displayName"/>
        <button
            class="rounded-md border border-sky-600 px-4 py-2 text-sm font-medium text-sky-700 transition hover:bg-sky-50"
            @onclick="SaveNameAsync">Save
        </button>
    </div>
</div>

<div class="mb-4 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold text-slate-900">Create Room</h2>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-12">
        <div class="md:col-span-4">
            <label class="mb-2 block text-sm font-medium text-slate-700">Room Name</label>
            <input
                class="w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
                @bind="newRoomName"/>
        </div>
        <div class="md:col-span-3">
            <label class="mb-2 block text-sm font-medium text-slate-700">Difficulty</label>
            <select
                class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
                @bind="newRoomDifficulty">
                <option value="@SyllableDifficulty.AtLeast500">500+ words</option>
                <option value="@SyllableDifficulty.AtMost500">No more than 500 words</option>
            </select>
        </div>
        <div class="md:col-span-2">
            <label class="mb-2 block text-sm font-medium text-slate-700">Time</label>
            <input
                class="w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
                type="number" min="5" max="30" @bind="newRoomSeconds"/>
        </div>
        <div class="md:col-span-2">
            <label class="mb-2 block text-sm font-medium text-slate-700">Lives</label>
            <input
                class="w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
                type="number" min="1" max="10" @bind="newRoomLives"/>
        </div>
        <div class="md:col-span-1 md:flex md:items-end">
            <button
                class="w-full rounded-md bg-sky-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-700"
                @onclick="CreateRoomAsync">Create
            </button>
        </div>
    </div>
</div>

<div class="mb-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Rooms</h2>
    @if (lobbyRooms.Count == 0)
    {
        <p class="mt-2 text-sm text-slate-600">No rooms yet.</p>
    }
</div>

<div class="grid grid-cols-1 gap-3 md:grid-cols-3">
    @foreach (var room in lobbyRooms)
    {
        <div class="h-full rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
            <div class="flex h-full flex-col gap-3">
                <p class="text-lg font-semibold text-slate-900">@room.Name</p>
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div class="flex flex-col gap-1">
                        <p class="text-slate-700">Player Count: @room.PlayersCount</p>
                        <p class="text-slate-700">Status: @RoomStatus(room)</p>
                    </div>
                    <div class="flex flex-col gap-1">
                        <p class="text-slate-700">Difficulty: @RoomDifficulty(room.Difficulty)</p>
                        <p class="text-slate-700">Lives: @room.MaxLives</p>
                    </div>
                </div>
                <button
                    class="mt-auto inline-flex w-fit rounded-md border border-sky-600 px-3 py-1.5 text-sm font-medium text-sky-700 transition hover:bg-sky-50"
                    @onclick="() => OpenRoom(room.RoomId)">Open
                </button>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(uiMessage))
{
    <p role="status"
       class="mt-4 rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800">@uiMessage</p>
}

@code {
    private HubConnection? connection;
    private string displayName = "Player";
    private string newRoomName = "Room";
    private int newRoomSeconds = 10;
    private int newRoomLives = 3;
    private SyllableDifficulty newRoomDifficulty = SyllableDifficulty.AtLeast500;
    private string uiMessage = string.Empty;
    private List<LobbyRoomDto> lobbyRooms = [];

    protected override async Task OnInitializedAsync()
    {
        connection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/multiplayer"))
            .WithAutomaticReconnect()
            .Build();

        connection.On<IReadOnlyCollection<LobbyRoomDto>>("LobbyUpdated",
            rooms =>
            {
                lobbyRooms = rooms.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase).ToList();
                return InvokeAsync(StateHasChanged);
            });

        connection.On<string>("DisplayNameUpdated",
            name =>
            {
                displayName = name;
                uiMessage = $"Display name set to {name}.";
                return InvokeAsync(StateHasChanged);
            });

        await connection.StartAsync();
    }

    private async Task SaveNameAsync()
    {
        if (connection is null)
            return;

        await connection.SendAsync("SetDisplayName", displayName);
    }

    private async Task CreateRoomAsync()
    {
        if (connection is null)
            return;

        var roomId = await connection.InvokeAsync<string?>("CreateRoom",
            newRoomName,
            newRoomDifficulty,
            newRoomSeconds,
            newRoomLives);

        if (string.IsNullOrWhiteSpace(roomId))
        {
            uiMessage = "Failed to create room.";
            return;
        }

        Navigation.NavigateTo($"/lobby/room/{roomId}");
        uiMessage = "Room created.";
    }

    private void OpenRoom(string roomId) => Navigation.NavigateTo($"/lobby/room/{roomId}");

    private static string RoomStatus(LobbyRoomDto room)
    {
        if (room.IsFinished)
            return "Finished";
        if (room.IsInProgress)
            return "In Progress";
        return "Waiting";
    }

    private static string RoomDifficulty(SyllableDifficulty difficulty)
    {
        return difficulty switch
        {
            SyllableDifficulty.AtLeast500 => "At least 500",
            SyllableDifficulty.AtMost500 => "At most 500",
            _ => "?"
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (connection is null)
            return;

        await connection.DisposeAsync();
    }

}
