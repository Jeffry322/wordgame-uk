@page "/solo"
@rendermode InteractiveServer
@implements IDisposable
@inject Dictionary GameDictionary

<PageTitle>Dictionary Game</PageTitle>

<h1 class="mb-6 text-3xl font-bold tracking-tight text-slate-900">Dictionary Game</h1>

@if (!gameStarted)
{
    <div class="mb-4">
        <label for="difficulty-input" class="mb-2 block text-sm font-medium text-slate-700">Difficulty</label>
        <select id="difficulty-input"
                class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
                @bind="selectedDifficulty">
            <option value="@SyllableDifficulty.AtLeast500">500+ words</option>
            <option value="@SyllableDifficulty.AtMost500">No more than 500 words</option>
        </select>
    </div>

    <div class="mb-4">
        <label for="time-input" class="mb-2 block text-sm font-medium text-slate-700">Round Time: @roundDurationSeconds s</label>
        <input id="time-input"
               class="h-2 w-full cursor-pointer appearance-none rounded-lg bg-slate-200 accent-sky-600"
               type="range"
               min="@MinRoundDurationSeconds"
               max="@MaxRoundDurationSeconds"
               @bind="roundDurationSeconds" />
    </div>

    <div class="mb-6">
        <label for="lives-input" class="mb-2 block text-sm font-medium text-slate-700">Lives (max timeouts): @lives</label>
        <input id="lives-input"
               class="h-2 w-full cursor-pointer appearance-none rounded-lg bg-slate-200 accent-sky-600"
               type="range"
               min="@MinLives"
               max="@MaxLives"
               @bind="lives" />
    </div>

    <button class="rounded-md bg-sky-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-700" @onclick="StartGame">
        Start Game
    </button>
}
else
{
    <p class="text-lg text-slate-700">Type a valid dictionary word that contains this syllable:</p>
    <p class="mb-2 text-3xl font-bold text-slate-900" role="status">@currentSyllable</p>
    <p class="mb-4 text-slate-700">Time left: <strong>@secondsLeft</strong>s</p>

    <form @onsubmit="SubmitWord" @onsubmit:preventDefault>
        <div class="mb-4">
            <label for="word-input" class="mb-2 block text-sm font-medium text-slate-700">Your word</label>
            <input id="word-input"
                   class="w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200"
                   @bind="userWord" />
        </div>

        <div class="flex gap-2">
            <button class="rounded-md bg-sky-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-700" type="submit">
                Submit
            </button>
            <button class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50" type="button" @onclick="StartGame">
                Restart Game
            </button>
        </div>
    </form>

    <p class="mt-4 text-sm text-slate-700">Rounds: @rounds | Correct: @correctAnswers | Wrong: @wrongGuesses | Timeouts: @timedOutRounds/@lives</p>
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <p class="mt-4 rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800" role="status">@statusMessage</p>
}

@code {
    private const int MinRoundDurationSeconds = 5;
    private const int MaxRoundDurationSeconds = 10;
    private const int MinLives = 1;
    private const int MaxLives = 10;
    private readonly Random random = new();
    private Timer? roundTimer;
    private bool gameStarted;
    private string currentSyllable = string.Empty;
    private string userWord = string.Empty;
    private string statusMessage = string.Empty;
    private int secondsLeft = 10;
    private int roundDurationSeconds = 10;
    private int lives = 3;
    private int rounds;
    private int correctAnswers;
    private int wrongGuesses;
    private int timedOutRounds;
    private SyllableDifficulty selectedDifficulty = SyllableDifficulty.AtLeast500;

    private void StartGame()
    {
        gameStarted = true;
        rounds = 0;
        correctAnswers = 0;
        wrongGuesses = 0;
        timedOutRounds = 0;
        userWord = string.Empty;
        statusMessage = string.Empty;
        secondsLeft = roundDurationSeconds;
        StartNextRound();
    }

    private void SubmitWord()
    {
        if (!gameStarted)
            return;

        var submittedWord = userWord;
        userWord = string.Empty;

        var isCorrect = GameDictionary.ContainsWord(submittedWord)
            && GameDictionary.ContainsSyllable(submittedWord, currentSyllable);

        if (isCorrect)
        {
            correctAnswers++;
            statusMessage = $"Correct: '{submittedWord}' contains '{currentSyllable}'.";
            StartNextRound();
        }
        else
        {
            wrongGuesses++;
            statusMessage = $"Wrong: '{submittedWord}' is not a valid match for '{currentSyllable}'. Try again.";
        }
    }

    private void StartNextRound()
    {
        currentSyllable = GameDictionary.GetRandomSyllable(random, selectedDifficulty);
        if (string.IsNullOrEmpty(currentSyllable))
        {
            StopTimer();
            gameStarted = false;
            statusMessage = $"No syllables are available for '{DifficultyLabel(selectedDifficulty)}'.";
            return;
        }

        rounds++;
        secondsLeft = roundDurationSeconds;
        RestartTimer();
    }

    private void RestartTimer()
    {
        StopTimer();
        roundTimer = new Timer(_ => _ = InvokeAsync(OnTimerTick), null, 1000, 1000);
    }

    private void StopTimer()
    {
        roundTimer?.Dispose();
        roundTimer = null;
    }

    private void OnTimerTick()
    {
        if (!gameStarted)
            return;

        secondsLeft--;

        if (secondsLeft > 0)
        {
            StateHasChanged();
            return;
        }

        timedOutRounds++;
        if (timedOutRounds >= lives)
        {
            statusMessage = $"Game over. You reached {timedOutRounds} timeout(s). Press Start Game to play again.";
            StopTimer();
            gameStarted = false;
            currentSyllable = string.Empty;
            StateHasChanged();
            return;
        }

        statusMessage = $"Time is up for '{currentSyllable}'.";
        userWord = string.Empty;
        StartNextRound();
        StateHasChanged();
    }

    public void Dispose()
    {
        StopTimer();
    }

    private static string DifficultyLabel(SyllableDifficulty difficulty)
    {
        return difficulty == SyllableDifficulty.AtLeast500
            ? "500+ words"
            : "No more than 500 words";
    }
}
